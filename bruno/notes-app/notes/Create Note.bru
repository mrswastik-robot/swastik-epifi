meta {
  name: Create Note
  type: http
  seq: 3
}

post {
  url: {{base_url}}/notes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "My First Note",
    "content": "This is the content of my first note."
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}
