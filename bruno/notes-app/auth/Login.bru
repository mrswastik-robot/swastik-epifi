meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{base_url}}/login
  body: json
  auth: none
}

body:json {
  {
    "email": "alice@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.access_token);
  }
}

assert {
  res.status: eq 200
  res.body.access_token: isDefined
}
